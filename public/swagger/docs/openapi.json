{
    "openapi": "3.0.3",
    "info": {
        "title": "Notes API",
        "description": "A RESTful API for managing user notes with authentication via Laravel Sanctum. All protected endpoints require a Bearer token obtained from `/register` or `/login`.",
        "version": "1.0.0"
    },
    "servers": [],
    "tags": [
        {
            "name": "Auth",
            "description": ""
        },
        {
            "name": "Notes",
            "description": ""
        }
    ],
    "components": {
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "token",
                "description": "Enter the token returned from `/register` or `/login`"
            }
        },
        "schemas": {
            "UserResource": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "John Doe"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "john@example.com"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-04-11 10:00:00"
                    }
                }
            },
            "NoteResource": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "title": {
                        "type": "string",
                        "example": "My first note"
                    },
                    "body": {
                        "type": "string",
                        "nullable": true,
                        "example": "This is the note content."
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-04-11 10:00:00"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-04-11 12:30:00"
                    }
                }
            },
            "PaginationMeta": {
                "type": "object",
                "properties": {
                    "current_page": {
                        "type": "integer",
                        "example": 1
                    },
                    "last_page": {
                        "type": "integer",
                        "example": 4
                    },
                    "per_page": {
                        "type": "integer",
                        "example": 15
                    },
                    "total": {
                        "type": "integer",
                        "example": 52
                    }
                }
            },
            "AuthData": {
                "type": "object",
                "properties": {
                    "user": {
                        "$ref": "#/components/schemas/UserResource"
                    },
                    "token": {
                        "type": "string",
                        "example": "10|auMVOIni2kQtIn7BtOd6zRNKqcqyFyLPh6C8lGrL1c31a2a1"
                    }
                }
            },
            "AuthResponse": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean",
                        "example": true
                    },
                    "message": {
                        "type": "string",
                        "example": "Registered successfully"
                    },
                    "data": {
                        "$ref": "#/components/schemas/AuthData"
                    }
                }
            },
            "LogoutResponse": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean",
                        "example": true
                    },
                    "message": {
                        "type": "string",
                        "example": "Logged out"
                    },
                    "data": {
                        "type": "array",
                        "items": {},
                        "example": []
                    }
                }
            },
            "NoteListResponse": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean",
                        "example": true
                    },
                    "message": {
                        "type": "string",
                        "example": "Data retrieved successfully"
                    },
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/NoteResource"
                        }
                    },
                    "pagination": {
                        "$ref": "#/components/schemas/PaginationMeta"
                    }
                }
            },
            "NoteSingleResponse": {
                "type": "object",
                "properties": {
                    "success": {
                        "type": "boolean",
                        "example": true
                    },
                    "message": {
                        "type": "string",
                        "example": "Data retrieved successfully"
                    },
                    "data": {
                        "$ref": "#/components/schemas/NoteResource"
                    }
                }
            },
            "RegisterRequest": {
                "type": "object",
                "required": ["name", "email", "password", "password_confirmation"],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "John Doe"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "john@example.com"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "minLength": 8,
                        "example": "secret123"
                    },
                    "password_confirmation": {
                        "type": "string",
                        "format": "password",
                        "example": "secret123"
                    }
                }
            },
            "LoginRequest": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "john@example.com"
                    },
                    "password": {
                        "type": "string",
                        "format": "password",
                        "example": "secret123"
                    }
                }
            },
            "StoreNoteRequest": {
                "type": "object",
                "required": ["title"],
                "properties": {
                    "title": {
                        "type": "string",
                        "minLength": 3,
                        "maxLength": 255,
                        "example": "Shopping list"
                    },
                    "body": {
                        "type": "string",
                        "nullable": true,
                        "example": "Milk, eggs, bread"
                    }
                }
            },
            "UpdateNoteRequest": {
                "type": "object",
                "description": "All fields are optional — send only what you want to change.",
                "properties": {
                    "title": {
                        "type": "string",
                        "minLength": 3,
                        "maxLength": 255,
                        "example": "Updated shopping list"
                    },
                    "body": {
                        "type": "string",
                        "nullable": true,
                        "example": "Milk, eggs, bread, butter"
                    }
                }
            },
            "ValidationErrorResponse": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "The given data was invalid."
                    },
                    "errors": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "example": {
                            "email": ["The email field is required."],
                            "password": ["The password must be at least 8 characters."]
                        }
                    }
                }
            },
            "UnauthenticatedResponse": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Unauthenticated."
                    }
                }
            },
            "ForbiddenResponse": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "This action is unauthorized."
                    }
                }
            },
            "NotFoundResponse": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string",
                        "example": "Record not found."
                    }
                }
            }
        },
        "responses": {
            "Unauthenticated": {
                "description": "Unauthenticated — missing or invalid Bearer token",
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "#/components/schemas/UnauthenticatedResponse"
                        }
                    }
                }
            },
            "Forbidden": {
                "description": "Forbidden — you do not own this resource",
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "#/components/schemas/ForbiddenResponse"
                        }
                    }
                }
            },
            "NotFound": {
                "description": "Not found",
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "#/components/schemas/NotFoundResponse"
                        }
                    }
                }
            },
            "ValidationError": {
                "description": "Validation error",
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "#/components/schemas/ValidationErrorResponse"
                        }
                    }
                }
            }
        },
        "parameters": {
            "NoteId": {
                "name": "note",
                "in": "path",
                "required": true,
                "description": "Note ID",
                "schema": {
                    "type": "integer",
                    "example": 1
                }
            },
            "Page": {
                "name": "page",
                "in": "query",
                "required": false,
                "description": "Page number for pagination",
                "schema": {
                    "type": "integer",
                    "default": 1,
                    "example": 1
                }
            }
        }
    },
    "paths": {
        "/register": {
            "post": {
                "tags": ["Auth"],
                "summary": "Register a new user",
                "operationId": "authRegister",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RegisterRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "User registered successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AuthResponse"
                                },
                                "example": {
                                    "success": true,
                                    "message": "Registered successfully",
                                    "data": {
                                        "user": {
                                            "id": 10,
                                            "name": "John Doe",
                                            "email": "john@example.com",
                                            "created_at": "2026-04-11 11:55:53"
                                        },
                                        "token": "10|auMVOIni2kQtIn7BtOd6zRNKqcqyFyLPh6C8lGrL1c31a2a1"
                                    }
                                }
                            }
                        }
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationError"
                    }
                }
            }
        },
        "/login": {
            "post": {
                "tags": ["Auth"],
                "summary": "Log in and receive a Bearer token",
                "operationId": "authLogin",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/LoginRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AuthResponse"
                                },
                                "example": {
                                    "success": true,
                                    "message": "Logged in successfully",
                                    "data": {
                                        "user": {
                                            "id": 10,
                                            "name": "John Doe",
                                            "email": "john@example.com",
                                            "created_at": "2026-04-11 11:55:53"
                                        },
                                        "token": "10|auMVOIni2kQtIn7BtOd6zRNKqcqyFyLPh6C8lGrL1c31a2a1"
                                    }
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Invalid credentials",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationErrorResponse"
                                },
                                "example": {
                                    "message": "The given data was invalid.",
                                    "errors": {
                                        "email": ["Invalid credentials"]
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/logout": {
            "post": {
                "tags": ["Auth"],
                "summary": "Revoke all tokens for the authenticated user",
                "operationId": "authLogout",
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Logged out successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/LogoutResponse"
                                },
                                "example": {
                                    "success": true,
                                    "message": "Logged out",
                                    "data": []
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/Unauthenticated"
                    }
                }
            }
        },
        "/notes": {
            "get": {
                "tags": ["Notes"],
                "summary": "List all notes for the authenticated user",
                "description": "Returns a paginated list of notes. Only notes belonging to the authenticated user are returned.",
                "operationId": "noteIndex",
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "parameters": [
                    {
                        "$ref": "#/components/parameters/Page"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Notes retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/NoteListResponse"
                                },
                                "example": {
                                    "success": true,
                                    "message": "Data retrieved successfully",
                                    "data": [
                                        {
                                            "id": 1,
                                            "title": "Shopping list",
                                            "body": "Milk, eggs, bread",
                                            "created_at": "2026-04-08 19:55:09",
                                            "updated_at": "2026-04-08 19:55:09"
                                        },
                                        {
                                            "id": 2,
                                            "title": "Meeting notes",
                                            "body": null,
                                            "created_at": "2026-04-09 14:20:00",
                                            "updated_at": "2026-04-09 14:20:00"
                                        }
                                    ],
                                    "pagination": {
                                        "current_page": 1,
                                        "last_page": 1,
                                        "per_page": 15,
                                        "total": 2
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/Unauthenticated"
                    }
                }
            },
            "post": {
                "tags": ["Notes"],
                "summary": "Create a new note",
                "operationId": "noteStore",
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/StoreNoteRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Note created successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/NoteSingleResponse"
                                },
                                "example": {
                                    "success": true,
                                    "message": "Note added successfully",
                                    "data": {
                                        "id": 3,
                                        "title": "Shopping list",
                                        "body": "Milk, eggs, bread",
                                        "created_at": "2026-04-11 10:00:00",
                                        "updated_at": "2026-04-11 10:00:00"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/Unauthenticated"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationError"
                    }
                }
            }
        },
        "/notes/{note}": {
            "get": {
                "tags": ["Notes"],
                "summary": "Get a single note",
                "operationId": "noteShow",
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "parameters": [
                    {
                        "$ref": "#/components/parameters/NoteId"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Note retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/NoteSingleResponse"
                                },
                                "example": {
                                    "success": true,
                                    "message": "Data retrieved successfully",
                                    "data": {
                                        "id": 1,
                                        "title": "Shopping list",
                                        "body": "Milk, eggs, bread",
                                        "created_at": "2026-04-08 19:55:09",
                                        "updated_at": "2026-04-08 19:55:09"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/Unauthenticated"
                    },
                    "403": {
                        "$ref": "#/components/responses/Forbidden"
                    },
                    "404": {
                        "$ref": "#/components/responses/NotFound"
                    }
                }
            },
            "put": {
                "tags": ["Notes"],
                "summary": "Update a note",
                "description": "Supports partial updates — send only the fields you want to change.",
                "operationId": "noteUpdate",
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "parameters": [
                    {
                        "$ref": "#/components/parameters/NoteId"
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UpdateNoteRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Note updated successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/NoteSingleResponse"
                                },
                                "example": {
                                    "success": true,
                                    "message": "Note updated successfully",
                                    "data": {
                                        "id": 1,
                                        "title": "Updated shopping list",
                                        "body": "Milk, eggs, bread, butter",
                                        "created_at": "2026-04-08 19:55:09",
                                        "updated_at": "2026-04-11 12:30:00"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/Unauthenticated"
                    },
                    "403": {
                        "$ref": "#/components/responses/Forbidden"
                    },
                    "404": {
                        "$ref": "#/components/responses/NotFound"
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationError"
                    }
                }
            },
            "delete": {
                "tags": ["Notes"],
                "summary": "Delete a note",
                "description": "Soft-deletes the note. The record is not permanently removed from the database.",
                "operationId": "noteDestroy",
                "security": [
                    {
                        "sanctum": []
                    }
                ],
                "parameters": [
                    {
                        "$ref": "#/components/parameters/NoteId"
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Note deleted — no content returned"
                    },
                    "401": {
                        "$ref": "#/components/responses/Unauthenticated"
                    },
                    "403": {
                        "$ref": "#/components/responses/Forbidden"
                    },
                    "404": {
                        "$ref": "#/components/responses/NotFound"
                    }
                }
            }
        }
    }
}
